{
  "name": "jekll-autocomplete",
  "displayName": "jekll-autocomplete",
  "description": "A VSCode extension that improves Jekyll blogging productivity by providing smart autocomplete, front matter snippets, and markdown writing helpers.",
  "publisher": "bienew22",
  "repository": {
    "type": "git",
    "url": "https://github.com/bienew22/jekyll-autocomplete"
  },
  "homepage": "https://github.com/bienew22/jekyll-autocomplete",
  "bugs": {
    "url": "https://github.com/bienew22/jekyll-autocomplete/issues"
  },
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jekll.autocomplete.openSettings",
        "title": "Jekll Autocomplete: Open Settings"
      },
      {
        "command": "jekyll.autocomplete.rebuildCache",
        "title": "Jekll Autocomplete: Rebuild Tag Cache"
      }
    ],
    "configuration": {
      "title": "Jekll Autocomplete Commands",
      "properties": {
        "jekll.autocomplete.commands": {
          "type": "object",
          "description": "사용자 정의 자동완성 명령어",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "sort": {
                "type": "string",
                "description": "정렬 순서 (문자열 숫자, 예: 001)"
              },
              "desc": {
                "type": "string",
                "description": "명령어 설명 텍스트"
              },
              "insert": {
                "type": "string",
                "description": "삽입될 스니펫"
              }
            },
            "required": [
              "insert"
            ]
          }
        },

        "jekll.autocomplete.gemini.api": {
          "type": "string",
          "description": "사용자의 gemini api key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "gray-matter": "^4.0.3"
  }
}
